# ============================================
# Variáveis de ambiente
# ============================================
# Copie este arquivo para .env antes de rodar:
#   cp .env.example .env
#
# O .env NÃO é commitado (está no .gitignore).
# Ajuste os valores conforme necessário.
# ============================================

# PostgreSQL
POSTGRES_USER=almocos
POSTGRES_PASSWORD=almocos
POSTGRES_DB=almocos_development

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=dev_secret_key_base_change_in_production

# Admin (usado pelo db:seed)
ADMIN_EMAIL=dev@almoco.com
ADMIN_NAME=Dev Admin
ADMIN_PASSWORD=dev123456
ADMIN_STAKE=Estaca Dev
ADMIN_WARD=Ala Dev
